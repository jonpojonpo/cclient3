{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#F5E6E8",
    "margin": 2
  },
  "block_quote": {
    "color": "#E8A0BF",
    "italic": true,
    "indent": 2,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": { "color": "#F5E6E8", "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#FF85A1", "bold": true },
  "h1": { "prefix": "✿ " },
  "h2": { "prefix": "❀ " },
  "h3": { "prefix": "✾ " },
  "h4": { "prefix": "#### " },
  "h5": { "prefix": "##### " },
  "h6": { "prefix": "###### " },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#E8A0BF", "italic": true },
  "strong": { "color": "#FFCBA4", "bold": true },
  "hr": { "color": "#C9A0DC", "format": "\n· · · · · ·\n" },
  "item": { "block_prefix": "♦ " },
  "enumeration": { "block_prefix": ". ", "color": "#FF85A1" },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#FF85A1", "underline": true },
  "link_text": { "color": "#E8A0BF" },
  "image": { "color": "#FF85A1", "underline": true },
  "image_text": { "color": "#E8A0BF", "format": "Image: {{.text}} →" },
  "code": { "color": "#FFCBA4" },
  "code_block": {
    "color": "#F5E6E8",
    "margin": 2,
    "chroma": {
      "text":                    { "color": "#F5E6E8" },
      "error":                   { "color": "#F5E6E8", "background_color": "#FF4757" },
      "comment":                 { "color": "#C9A0DC" },
      "comment_preproc":        { "color": "#E8A0BF" },
      "keyword":                 { "color": "#FF85A1" },
      "keyword_reserved":        { "color": "#FF85A1" },
      "keyword_namespace":       { "color": "#FF85A1" },
      "keyword_type":            { "color": "#FFCBA4" },
      "operator":                { "color": "#E8A0BF" },
      "punctuation":             { "color": "#F5E6E8" },
      "name":                    { "color": "#FFB3C6" },
      "name_builtin":            { "color": "#FFB3C6" },
      "name_tag":                { "color": "#FF85A1" },
      "name_attribute":          { "color": "#FFCBA4" },
      "name_class":              { "color": "#FF85A1" },
      "name_constant":           { "color": "#C9A0DC" },
      "name_decorator":          { "color": "#FFCBA4" },
      "name_exception":          {},
      "name_function":           { "color": "#FFB3C6" },
      "name_other":              {},
      "literal":                 {},
      "literal_number":          { "color": "#C9A0DC" },
      "literal_date":            {},
      "literal_string":          { "color": "#FFCBA4" },
      "literal_string_escape":   { "color": "#E8A0BF" },
      "generic_deleted":         { "color": "#FF4757" },
      "generic_emph":            { "color": "#E8A0BF", "italic": true },
      "generic_inserted":        { "color": "#FFCBA4" },
      "generic_strong":          { "color": "#FF85A1", "bold": true },
      "generic_subheading":      { "color": "#FFB3C6" },
      "background":              { "background_color": "#2D1B2E" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n→ " },
  "html_block": {},
  "html_span": {}
}
