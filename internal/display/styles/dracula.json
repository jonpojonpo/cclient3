{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#F8F8F2",
    "margin": 2
  },
  "block_quote": {
    "color": "#6272A4",
    "italic": true,
    "indent": 2,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "color": "#F8F8F2",
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#BD93F9",
    "bold": true
  },
  "h1": { "prefix": "# " },
  "h2": { "prefix": "## " },
  "h3": { "prefix": "### " },
  "h4": { "prefix": "#### " },
  "h5": { "prefix": "##### " },
  "h6": { "prefix": "###### " },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#FF79C6", "italic": true },
  "strong": { "color": "#FFB86C", "bold": true },
  "hr": { "color": "#44475A", "format": "\n--------\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". ", "color": "#BD93F9" },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#8BE9FD", "underline": true },
  "link_text": { "color": "#FF79C6" },
  "image": { "color": "#8BE9FD", "underline": true },
  "image_text": { "color": "#FF79C6", "format": "Image: {{.text}} →" },
  "code": { "color": "#50FA7B" },
  "code_block": {
    "color": "#F8F8F2",
    "margin": 2,
    "chroma": {
      "text":                    { "color": "#F8F8F2" },
      "error":                   { "color": "#F8F8F2", "background_color": "#FF5555" },
      "comment":                 { "color": "#6272A4" },
      "comment_preproc":         { "color": "#FF79C6" },
      "keyword":                 { "color": "#FF79C6" },
      "keyword_reserved":        { "color": "#FF79C6" },
      "keyword_namespace":       { "color": "#FF79C6" },
      "keyword_type":            { "color": "#8BE9FD" },
      "operator":                { "color": "#FF79C6" },
      "punctuation":             { "color": "#F8F8F2" },
      "name":                    { "color": "#F8F8F2" },
      "name_builtin":            { "color": "#8BE9FD" },
      "name_tag":                { "color": "#FF79C6" },
      "name_attribute":          { "color": "#50FA7B" },
      "name_class":              { "color": "#8BE9FD" },
      "name_constant":           { "color": "#BD93F9" },
      "name_decorator":          { "color": "#50FA7B" },
      "name_exception":          {},
      "name_function":           { "color": "#50FA7B" },
      "name_other":              {},
      "literal":                 {},
      "literal_number":          { "color": "#BD93F9" },
      "literal_date":            {},
      "literal_string":          { "color": "#F1FA8C" },
      "literal_string_escape":   { "color": "#FF79C6" },
      "generic_deleted":         { "color": "#FF5555" },
      "generic_emph":            { "color": "#FF79C6", "italic": true },
      "generic_inserted":        { "color": "#50FA7B" },
      "generic_strong":          { "color": "#FFB86C", "bold": true },
      "generic_subheading":      { "color": "#BD93F9" },
      "background":              { "background_color": "#282A36" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n→ " },
  "html_block": {},
  "html_span": {}
}
