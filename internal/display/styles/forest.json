{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#D4E6C3",
    "margin": 2
  },
  "block_quote": {
    "color": "#6BAE75",
    "italic": true,
    "indent": 2,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": { "color": "#D4E6C3", "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#52B788", "bold": true },
  "h1": { "prefix": "🌲 " },
  "h2": { "prefix": "🌿 " },
  "h3": { "prefix": "🍃 " },
  "h4": { "prefix": "#### " },
  "h5": { "prefix": "##### " },
  "h6": { "prefix": "###### " },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#6BAE75", "italic": true },
  "strong": { "color": "#D4AC0D", "bold": true },
  "hr": { "color": "#40916C", "format": "\n〰〰〰〰〰〰\n" },
  "item": { "block_prefix": "▸ " },
  "enumeration": { "block_prefix": ". ", "color": "#52B788" },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#52B788", "underline": true },
  "link_text": { "color": "#6BAE75" },
  "image": { "color": "#52B788", "underline": true },
  "image_text": { "color": "#6BAE75", "format": "Image: {{.text}} →" },
  "code": { "color": "#95D5B2" },
  "code_block": {
    "color": "#D4E6C3",
    "margin": 2,
    "chroma": {
      "text":                    { "color": "#D4E6C3" },
      "error":                   { "color": "#D4E6C3", "background_color": "#BC4749" },
      "comment":                 { "color": "#40916C" },
      "comment_preproc":        { "color": "#74C69D" },
      "keyword":                 { "color": "#52B788" },
      "keyword_reserved":        { "color": "#52B788" },
      "keyword_namespace":       { "color": "#52B788" },
      "keyword_type":            { "color": "#95D5B2" },
      "operator":                { "color": "#6BAE75" },
      "punctuation":             { "color": "#D4E6C3" },
      "name":                    { "color": "#74C69D" },
      "name_builtin":            { "color": "#74C69D" },
      "name_tag":                { "color": "#52B788" },
      "name_attribute":          { "color": "#95D5B2" },
      "name_class":              { "color": "#B7E4C7" },
      "name_constant":           { "color": "#D4AC0D" },
      "name_decorator":          { "color": "#6BAE75" },
      "name_exception":          {},
      "name_function":           { "color": "#95D5B2" },
      "name_other":              {},
      "literal":                 {},
      "literal_number":          { "color": "#D4AC0D" },
      "literal_date":            {},
      "literal_string":          { "color": "#B7E4C7" },
      "literal_string_escape":   { "color": "#74C69D" },
      "generic_deleted":         { "color": "#BC4749" },
      "generic_emph":            { "color": "#6BAE75", "italic": true },
      "generic_inserted":        { "color": "#52B788" },
      "generic_strong":          { "color": "#D4AC0D", "bold": true },
      "generic_subheading":      { "color": "#52B788" },
      "background":              { "background_color": "#1B2D23" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n→ " },
  "html_block": {},
  "html_span": {}
}
