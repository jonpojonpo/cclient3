{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#D8DEE9",
    "margin": 2
  },
  "block_quote": {
    "color": "#81A1C1",
    "italic": true,
    "indent": 2,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "color": "#D8DEE9",
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#88C0D0",
    "bold": true
  },
  "h1": { "prefix": "# " },
  "h2": { "prefix": "## " },
  "h3": { "prefix": "### " },
  "h4": { "prefix": "#### " },
  "h5": { "prefix": "##### " },
  "h6": { "prefix": "###### " },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#81A1C1", "italic": true },
  "strong": { "color": "#EBCB8B", "bold": true },
  "hr": { "color": "#4C566A", "format": "\n--------\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". ", "color": "#88C0D0" },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#88C0D0", "underline": true },
  "link_text": { "color": "#81A1C1" },
  "image": { "color": "#88C0D0", "underline": true },
  "image_text": { "color": "#81A1C1", "format": "Image: {{.text}} →" },
  "code": { "color": "#A3BE8C" },
  "code_block": {
    "color": "#D8DEE9",
    "margin": 2,
    "chroma": {
      "text":                    { "color": "#D8DEE9" },
      "error":                   { "color": "#D8DEE9", "background_color": "#BF616A" },
      "comment":                 { "color": "#616E88" },
      "comment_preproc":         { "color": "#5E81AC" },
      "keyword":                 { "color": "#81A1C1" },
      "keyword_reserved":        { "color": "#81A1C1" },
      "keyword_namespace":       { "color": "#81A1C1" },
      "keyword_type":            { "color": "#8FBCBB" },
      "operator":                { "color": "#81A1C1" },
      "punctuation":             { "color": "#D8DEE9" },
      "name":                    { "color": "#88C0D0" },
      "name_builtin":            { "color": "#88C0D0" },
      "name_tag":                { "color": "#81A1C1" },
      "name_attribute":          { "color": "#8FBCBB" },
      "name_class":              { "color": "#8FBCBB" },
      "name_constant":           { "color": "#5E81AC" },
      "name_decorator":          { "color": "#A3BE8C" },
      "name_exception":          {},
      "name_function":           { "color": "#88C0D0" },
      "name_other":              {},
      "literal":                 {},
      "literal_number":          { "color": "#B48EAD" },
      "literal_date":            {},
      "literal_string":          { "color": "#A3BE8C" },
      "literal_string_escape":   { "color": "#EBCB8B" },
      "generic_deleted":         { "color": "#BF616A" },
      "generic_emph":            { "color": "#81A1C1", "italic": true },
      "generic_inserted":        { "color": "#A3BE8C" },
      "generic_strong":          { "color": "#EBCB8B", "bold": true },
      "generic_subheading":      { "color": "#88C0D0" },
      "background":              { "background_color": "#2E3440" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n→ " },
  "html_block": {},
  "html_span": {}
}
