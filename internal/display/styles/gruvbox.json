{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#EBDBB2",
    "margin": 2
  },
  "block_quote": {
    "color": "#D79921",
    "italic": true,
    "indent": 2,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": { "color": "#EBDBB2", "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#FABD2F", "bold": true },
  "h1": { "prefix": "# " },
  "h2": { "prefix": "## " },
  "h3": { "prefix": "### " },
  "h4": { "prefix": "#### " },
  "h5": { "prefix": "##### " },
  "h6": { "prefix": "###### " },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#D3869B", "italic": true },
  "strong": { "color": "#FE8019", "bold": true },
  "hr": { "color": "#928374", "format": "\n--------\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". ", "color": "#FABD2F" },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#83A598", "underline": true },
  "link_text": { "color": "#D79921" },
  "image": { "color": "#83A598", "underline": true },
  "image_text": { "color": "#D79921", "format": "Image: {{.text}} →" },
  "code": { "color": "#B8BB26" },
  "code_block": {
    "color": "#EBDBB2",
    "margin": 2,
    "chroma": {
      "text":                    { "color": "#EBDBB2" },
      "error":                   { "color": "#EBDBB2", "background_color": "#CC241D" },
      "comment":                 { "color": "#928374" },
      "comment_preproc":        { "color": "#8EC07C" },
      "keyword":                 { "color": "#FB4934" },
      "keyword_reserved":        { "color": "#FB4934" },
      "keyword_namespace":       { "color": "#FB4934" },
      "keyword_type":            { "color": "#FABD2F" },
      "operator":                { "color": "#FB4934" },
      "punctuation":             { "color": "#EBDBB2" },
      "name":                    { "color": "#83A598" },
      "name_builtin":            { "color": "#83A598" },
      "name_tag":                { "color": "#FB4934" },
      "name_attribute":          { "color": "#B8BB26" },
      "name_class":              { "color": "#FABD2F" },
      "name_constant":           { "color": "#D3869B" },
      "name_decorator":          { "color": "#B8BB26" },
      "name_exception":          {},
      "name_function":           { "color": "#B8BB26" },
      "name_other":              {},
      "literal":                 {},
      "literal_number":          { "color": "#D3869B" },
      "literal_date":            {},
      "literal_string":          { "color": "#B8BB26" },
      "literal_string_escape":   { "color": "#FE8019" },
      "generic_deleted":         { "color": "#FB4934" },
      "generic_emph":            { "color": "#D3869B", "italic": true },
      "generic_inserted":        { "color": "#B8BB26" },
      "generic_strong":          { "color": "#FE8019", "bold": true },
      "generic_subheading":      { "color": "#FABD2F" },
      "background":              { "background_color": "#282828" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n→ " },
  "html_block": {},
  "html_span": {}
}
